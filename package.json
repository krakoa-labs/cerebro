{
  "name": "@krakoa-labs/cerebro",
  "version": "0.0.0",
  "description": "Locate every component across your apps.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cerebro": "dist/cli.js"
  },
  "files": ["dist", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install || true",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.17.10",
    "lefthook": "^1.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "design-system",
    "react",
    "typescript",
    "observability",
    "cli",
    "krakoa-labs",
    "cerebro"
  ]
}
